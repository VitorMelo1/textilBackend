# Shared
ENV=dev
DATABASE_URL=postgresql+asyncpg://textil:textil@postgres:5432/textil
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-in-dev
JWT_ISSUER=duonekso
JWT_AUDIENCE=duonekso-web
SESSION_SECRET=change-me-in-dev
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
ACCESS_COOKIE_NAME=duonekso_access_token
REFRESH_COOKIE_NAME=duonekso_refresh_token

# core-api (OAuth + CORS para frontend Vite)
CORE_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback

# Billing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# chat-service
CHAT_SERVICE_BASE_URL=http://localhost:8001

# Observabilidade (opcional): DSN do Sentry para monitoramento de erros
SENTRY_DSN=
